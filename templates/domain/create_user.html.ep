<h1>Create user in <%=$domain%></h1>
<form action="/domain/<%=$domain%>/create-user" method="POST">
	<label for="input_username">Username:</label> <input type="text" name="username" id="input_username"/>
	<label for="input_password">Password:</label> <input type="password" name="password" id="input_password"/>
	<button type="submit">Submit</button>
</form>
